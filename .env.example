PORT=3210
KUBECTL_PATH=kubectl
SESSION_MAX_COUNT=30

# Third-party LLM endpoint used by Codex SDK.
# Prefer the LLM_* names below; CODEX_* are still supported as fallback.
LLM_BASE_URL=https://your-llm-gateway.example.com
LLM_MODEL=gpt-5
LLM_API_KEY=your_api_key_here

# Optional fallback names if you prefer to keep Codex-style env vars.
# CODEX_BASE_URL=https://your-llm-gateway.example.com
# CODEX_MODEL=gpt-5
# CODEX_API_KEY=your_api_key_here
